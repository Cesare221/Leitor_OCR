# Configuracoes do OCR hibrido
OCR_USE_GEMINI=true
OCR_USE_DOCUMENTAI=true
OCR_STABLE_PRODUCTION_MODE=true
OCR_GEMINI_MAX_CONCURRENCY=4
OCR_GEMINI_STABLE_MAX_CONCURRENCY=4
OCR_GEMINI_SMALL_DPI=180
OCR_GEMINI_MEDIUM_DPI=160
OCR_GEMINI_LARGE_DPI=140
OCR_GEMINI_MIN_ROWS_PER_PAGE=8
OCR_GEMINI_LOCATION=southamerica-east1
OCR_GEMINI_MODEL=gemini-2.5-flash
OCR_GEMINI_FAST_MODEL=gemini-2.0-flash-lite
OCR_GEMINI_STRONG_MODEL=gemini-2.5-flash
OCR_ENABLE_FAST_MODEL_FIRST_PASS=true
OCR_GEMINI_FAST_MODEL_AVAILABLE=false
OCR_GEMINI_WARMUP_ENABLED=true
OCR_GEMINI_WARMUP_TIMEOUT_SECONDS=8
OCR_GEMINI_WARMUP_TTL_SECONDS=1800
OCR_GEMINI_FAST_TIMEOUT_SECONDS=45
OCR_GEMINI_STRONG_TIMEOUT_SECONDS=90
OCR_GEMINI_FAST_RETRIES=1
OCR_GEMINI_STRONG_RETRIES=2
OCR_TIMING_LOGS=true
OCR_ENABLE_SMART_REFINE=false
OCR_SMART_REFINE_MAX_PAGES=1
OCR_GEMINI_HQ_DPI=240
OCR_GEMINI_HQ_FORMAT=jpeg
OCR_GEMINI_HQ_JPEG_QUALITY=88
OCR_ENABLE_VISUAL_ABSENCE_GUARD=true
OCR_ENABLE_RAPIDOCR=true
OCR_RAPIDOCR_MIN_CONFIDENCE=0.45
OCR_JOB_WORKERS=3
# OCR_GEMINI_API_KEY=sua-api-key
# Em producao no Cloud Run, a API key e opcional se a service account
# ja tiver permissao para chamar Vertex AI via ADC.

# Configuracoes do Google Cloud Document AI
OCR_DOCUMENTAI_PROJECT_ID=listreader
OCR_DOCUMENTAI_LOCATION=us
OCR_DOCUMENTAI_PROCESSOR_ID=c50310d2f5b3f7a7

# Configuracoes do Google Cloud Storage (opcional, se usar nuvem)
# OCR_STORAGE_MODE=cloud
# OCR_GCS_BUCKET=seu-bucket-do-gcs

# Configuracoes adicionais (opcional)
# OCR_WEB_HOST=127.0.0.1
# OCR_WEB_PORT=8000
